# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Tavily API key for web search — get yours at https://tavily.com
TAVILY_API_KEY=tvly-...

# ── Core agent ────────────────────────────────────────────────────────────────
# JARVIS_MODEL=claude-sonnet-4-6
# JARVIS_MAX_TOKENS=8096
# JARVIS_REPORTS_DIR=reports
# JARVIS_MAX_SEARCH_CALLS=20
# JARVIS_ALLOWED_COMMANDS=ls,dir,cat,echo,python,python3,git,pwd,whoami,date

# ── Multi-model routing ────────────────────────────────────────────────────────
# JARVIS_ROUTING_STRATEGY=always_primary   # "always_primary" or "smart"
# JARVIS_FAST_MODEL=claude-haiku-4-5-20251001  # model used for tool-dispatch turns in smart mode

# ── Local model (Ollama) ───────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Voice mode ────────────────────────────────────────────────────────────────
# Requires: pip install "jarvis[voice]"
# JARVIS_TTS_ENGINE=local          # "local" (pyttsx3) or "elevenlabs"
# JARVIS_WHISPER_MODEL=base        # tiny | base | small | medium | large
# ELEVENLABS_API_KEY=              # only if JARVIS_TTS_ENGINE=elevenlabs
# JARVIS_ELEVENLABS_VOICE=Rachel

# ── Wake word / ambient mode ──────────────────────────────────────────────────
# Requires: pip install "jarvis[wake-word]"
# PICOVOICE_ACCESS_KEY=            # get free key at https://picovoice.ai

# ── API server ────────────────────────────────────────────────────────────────
# JARVIS_API_HOST=0.0.0.0
# JARVIS_API_PORT=8000
# JARVIS_SESSION_TTL_MINUTES=60

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
# RABBITMQ_URL=amqp://guest:guest@localhost:5672/
# RABBITMQ_TASK_QUEUE=jarvis.tasks

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# JARVIS_AUTH_ENABLED=false
# JARVIS_JWT_SECRET=change-me-in-production   # change this before deploying!
# JARVIS_JWT_EXPIRE_MINUTES=1440              # 24 hours

# ── OpenTelemetry tracing ─────────────────────────────────────────────────────
# JARVIS_OTEL_ENABLED=false
# Otel endpoint — points to Grafana Tempo (included in docker-compose)
# OTL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Edge agent (MQTT) ─────────────────────────────────────────────────────────
# Used by `jarvis-edge` CLI when connecting to a remote JARVIS API
# MQTT_HOST=localhost
# MQTT_PORT=1883

# ── Auto-training pipeline ────────────────────────────────────────────────────
# Set JARVIS_AUTO_TRAINING=true to enable fully automatic crawl + fine-tune
# Requires ANTHROPIC_API_KEY (for synthetic data generation) and mlx-lm installed
# JARVIS_AUTO_TRAINING=true
# JARVIS_TRAINING_TOPICS=RLHF,transformers,constitutional AI,multimodal systems,memory systems
# JARVIS_AUTO_CRAWL_CRON=0 1 * * *        # daily at 01:00 UTC
# JARVIS_AUTO_FINETUNE_CRON=0 3 * * 0     # every Sunday at 03:00 UTC
# JARVIS_FT_MODEL_NAME=jarvis-ft
# JARVIS_TRAINING_MIN_NEW_DOCS=5           # skip fine-tune if fewer new docs than this
# JARVIS_TRAINING_MAX_PAPERS=10            # max papers per source per crawl
# JARVIS_TRAINING_TARGET_PAIRS=500         # target Q&A pairs per fine-tune run
# JARVIS_TRAINING_LORA_RANK=16
# JARVIS_TRAINING_EPOCHS=3
# JARVIS_TRAINING_DIR=reports/training     # where JSONL datasets are saved
# JARVIS_TRAINING_BASE_MODEL=mlx-community/Qwen2.5-14B-Instruct-4bit

# ── Eval-triggered training ───────────────────────────────────────────────────
# Run eval suite on a schedule; if pass_rate < threshold, trigger fine-tuning.
# Requires JARVIS_AUTO_TRAINING=true for the fine-tune step to run.
# JARVIS_AUTO_EVAL=false
# JARVIS_EVAL_CRON=0 22 * * 6              # every Saturday at 22:00 UTC
# JARVIS_EVAL_THRESHOLD=0.8                # trigger fine-tune if pass_rate drops below this
